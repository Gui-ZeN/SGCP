rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    //  HELPERS
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Usuário autenticado E com e-mail verificado.
    // O login do app é Google Sign-In, que sempre define email_verified == true.
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Caminho do documento do usuário corrente na coleção `usuarios`
    // (o ID do documento é o e-mail, conforme src/hooks/useMetadata.ts).
    function userPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.token.email);
    }

    // Usuário autenticado que possui registro na coleção `usuarios`.
    function isRegistered() {
      return isSignedIn() && exists(userPath());
    }

    // Papel ("role") do usuário corrente. Só chamar após isRegistered().
    function roleOf() {
      return get(userPath()).data.role;
    }

    // Administrador: papel "Administrador" no cadastro `usuarios` (sem admin
    // bootstrap por e-mail — os admins vêm 100% da coleção `usuarios`).
    function isAdmin() {
      return isRegistered() && roleOf() == "Administrador";
    }

    // Editor: pode criar/editar/excluir dados operacionais.
    // Inclui Administrador e Analista. Visualizador é somente leitura.
    // Usuário autenticado mas SEM registro em `usuarios` NÃO é editor
    // (espelha a tela de "não autorizado" do app para contas não cadastradas).
    function isEditor() {
      return isAdmin()
        || (isRegistered() && roleOf() in ['Administrador', 'Coordenador', 'Analista']);
    }

    // Coordenador: admin regional. Pode ler logs (o escopo por região é aplicado no app).
    function isCoordenador() {
      return isRegistered() && roleOf() == "Coordenador";
    }

    // Usuário do app: verificado E provisionado (admin bootstrap ou cadastrado
    // em `usuarios`). Mais restrito que isVerifiedUser(), pois o login Google
    // não tem restrição de domínio — sem isto, qualquer conta Google poderia
    // ler dados sensíveis (entrevistas de desligamento, período de experiência).
    function isAppUser() {
      return isVerifiedUser() && (isAdmin() || isRegistered());
    }

    // Validação do documento de usuário (escrita sempre grava o objeto completo).
    function isValidUsuario() {
      let d = incoming();
      return d.email is string
        && d.email.size() <= 320
        && d.role in ['Administrador', 'Coordenador', 'Analista', 'Visualizador']
        && (!('sede' in d.keys()) || d.sede is string);
    }

    // =====================================================================
    //  VAGAS  (dados de requisição de vaga)
    // =====================================================================
    //  Leitura: usuários do app (verificados e provisionados).
    //  A integração externa de Absenteísmo (Apps Script) lê esta coleção via
    //  service account (IAM, papel Cloud Datastore Viewer), que NÃO passa pelas
    //  regras de segurança — ver opção (a) em SECURITY_FIRESTORE_RULES.md.
    //  Escrita: apenas editores (Admin/Analista).
    match /vagas/{vagaId} {
      allow read: if isAppUser();
      allow create, update, delete: if isEditor();
    }

    // =====================================================================
    //  COLEÇÕES ADMINISTRATIVAS  (escrita só de Administrador)
    // =====================================================================

    // Usuários e papéis. Leitura por qualquer usuário verificado porque o
    // app precisa listar `usuarios` na inicialização para descobrir o papel
    // do usuário corrente (src/hooks/useMetadata.ts). Escrita só de admin.
    match /usuarios/{email} {
      allow read: if isAppUser();
      // Coordenador gerencia usuários do Colégio, mas NUNCA mexe em Administrador
      // (não cria, não promove, não edita/exclui admin) — evita escalonar privilégio.
      // A restrição por região fica no app (usuario.sede é nome; as regras não
      // conseguem cruzar nome→região sem query).
      allow create: if (isAdmin() || (isCoordenador() && incoming().role != 'Administrador')) && isValidUsuario();
      allow update: if (isAdmin() || (isCoordenador() && incoming().role != 'Administrador' && existing().role != 'Administrador')) && isValidUsuario();
      allow delete: if isAdmin() || (isCoordenador() && existing().role != 'Administrador');
    }

    match /sedes/{sedeId} {
      allow read: if isAppUser();
      // Coordenador gerencia sedes do Colégio (região != Universidade). A região
      // está no próprio documento, então aqui a trava por unidade é de verdade (servidor).
      allow create: if isAdmin() || (isCoordenador() && incoming().regiao != 'Universidade');
      allow update: if isAdmin() || (isCoordenador() && existing().regiao != 'Universidade' && incoming().regiao != 'Universidade');
      allow delete: if isAdmin() || (isCoordenador() && existing().regiao != 'Universidade');
    }

    match /regioes/{regiaoId} {
      allow read: if isAppUser();
      allow write: if isAdmin();
    }

    match /cargos/{cargoId} {
      allow read: if isAppUser();
      allow write: if isAdmin();
    }

    match /setores/{setorId} {
      allow read: if isAppUser();
      allow write: if isAdmin();
    }

    // Configuração interna do sistema. Nenhum cliente lê isto hoje, então
    // mantemos no menor privilégio: somente Administrador lê e escreve.
    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }

    // =====================================================================
    //  COLEÇÕES OPERACIONAIS  (leitura: usuário do app; escrita: editor)
    //  Contêm dados pessoais de colaboradores (entrevistas de desligamento,
    //  período de experiência etc.), por isso a leitura exige autenticação.
    // =====================================================================

    match /treinamentos/{treinamentoId} {
      allow read: if isAppUser();
      allow write: if isEditor();
    }

    match /experiencia/{experienciaId} {
      allow read: if isAppUser();
      allow write: if isEditor();
    }

    match /entrevistas/{entrevistaId} {
      allow read: if isAppUser();
      allow write: if isEditor();
    }

    match /turnover/{turnoverId} {
      allow read: if isAppUser();
      allow write: if isEditor();
    }

    // =====================================================================
    //  LOGS DE AUDITORIA  (append-only)
    //  Leitura só de Administrador (o app só assina os logs quando admin).
    //  Criação por editores (que geram os eventos). Sem update/delete para
    //  preservar a integridade da trilha de auditoria.
    // =====================================================================
    match /logs/{logId} {
      allow read: if isAdmin() || isCoordenador(); // Coordenador lê logs; o filtro por região é no app

      allow create: if isEditor()
        && incoming().usuario is string
        && incoming().acao in ['CRIOU', 'ALTEROU', 'EXCLUIU', 'SINALIZOU'];
      allow update, delete: if false;
    }

    // =====================================================================
    //  NEGAÇÃO PADRÃO  — qualquer outro caminho é bloqueado.
    // =====================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
